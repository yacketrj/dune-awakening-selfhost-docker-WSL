# SERVER_IP is the address external clients should use.
# Use "auto" to detect the current public IPv4 at runtime, or set it manually.
SERVER_IP=auto

# SERVER_BIND_IP is the local interface/IP the game sockets listen on.
# Leave unset for auto-detection, or set it to the Docker host LAN/public interface IP.
# In NAT/port-forward setups, SERVER_BIND_IP is usually the LAN IP and SERVER_IP is the public WAN IP.
# Example:
# SERVER_BIND_IP=10.0.0.240
# SERVER_IP_MODE=public
# SERVER_IP=109.150.247.52
SERVER_IP_MODE=public
# SERVER_BIND_IP=

# Docker Desktop/WSL2 only: override where game servers connect for RabbitMQ.
# Native Linux normally uses 127.0.0.1 automatically.
# DUNE_RMQ_GAME_HOST=
# DUNE_RMQ_ADMIN_HOST=
# RabbitMQ game HTTP/management binds to localhost by default.
# Set only when this internal endpoint is protected by a firewall or VPN.
# RMQ_GAME_HTTP_BIND=127.0.0.1

# Advanced legacy escape hatch only. Do not enable for NAT/port-forward hosting.
# DUNE_ALLOW_GAME_EXTERNAL_ADDRESS_OVERRIDE=0

# Public name players should see.
SERVER_TITLE="My Dune Server"

# Usually "Europe Test" or "North America Test".
SERVER_REGION="Europe Test"

# Provider/datacenter label shown by Funcom server browser if supported.
SERVER_PROVIDER="dune-docker"

STEAM_APP_ID=4754530

# This must match the battlegroup/self-host identity authorized by the Funcom token.
# Example:
# BATTLEGROUP_ID=sh-xxxxxxxxxxxxxxxx-xxxxx
BATTLEGROUP_ID=

# Do NOT commit your Funcom Self-Host Service Token.
# Put it in:
# runtime/secrets/funcom-token.txt

# Optional Dune Docker Console web UI.
# Bind locally by default because the web console can control the Docker daemon.
# Set ADMIN_BIND_HOST=auto or a specific trusted interface only when protected by
# a firewall, VPN, or TLS-terminating reverse proxy.
ADMIN_BIND_HOST=127.0.0.1
ADMIN_BIND_PORT=8088
ADMIN_AUTH_DISABLED=0
ADMIN_SECURE_COOKIES=0
ADMIN_PASSWORD=
ADMIN_TASK_RETENTION=200
ADMIN_COMMAND_TIMEOUT_MS=120000
ADMIN_MAX_JSON_BYTES=2097152
ADMIN_MAX_UPLOAD_BYTES=134217728
ADMIN_MAX_SSE_CONNECTIONS=20
ADMIN_DB_POOL_SIZE=5
ADMIN_DB_CONNECT_TIMEOUT_MS=3000
ADMIN_DB_QUERY_TIMEOUT_MS=15000
ADMIN_DB_STATEMENT_TIMEOUT_MS=15000
ALLOW_HOST_BOOTSTRAP=false
ADMIN_MOCK_MODE=0
ADMIN_CONTAINER_MEMORY_LIMIT=512m
ADMIN_CONTAINER_CPUS=1.0
ADMIN_CONTAINER_PIDS_LIMIT=256

# Optional experimental read-only Discord adapter API.
# Disabled by default. Use a strong random token or a token file path.
DUNE_DISCORD_ADAPTER_ENABLED=false
# DUNE_DISCORD_ADAPTER_TOKEN=
# DUNE_DISCORD_ADAPTER_TOKEN_FILE=
# DISCORD_OBSERVER_ROLE_IDS=
# DISCORD_ADMIN_ROLE_IDS=
# DISCORD_OWNER_ROLE_IDS=

# Optional direct database overrides for the web admin.
# ADMIN_DATABASE_URL=postgres://dune:dune@127.0.0.1:15432/dune
# DUNE_DB_HOST=127.0.0.1
# DUNE_DB_PORT=15432
# DUNE_DB_NAME=dune
# DUNE_DB_USER=dune
# Defaults to runtime/secrets/dune-db-password.txt generated by start-postgres.
# DUNE_DB_PASSWORD=

# Optional RabbitMQ/server-command override. Normally the web admin reads or
# creates runtime/secrets/command-auth-token.txt with local 0600 permissions.
# DUNE_COMMAND_AUTH_TOKEN=
# RMQ_GAME_TLS_VERIFY=verify_peer
# RMQ_GAME_TLS_FAIL_IF_NO_PEER_CERT=false

# Optional runtime path override when the web admin is run outside this repo.
# DUNE_DOCKER_DIR=/path/to/dune-awakening-selfhost-docker
